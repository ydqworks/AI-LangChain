# 复制到 packages/agent/.env（langgraph.json 的 env 路径相对 agent 包根目录）

# Required: Google Gemini API key（https://aistudio.google.com/apikey）
GOOGLE_API_KEY=your-api-key-here

# Optional: 本地代理（Gemini「User location is not supported」时启用）
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# Optional: LangSmith tracing（https://smith.langchain.com）
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your_key_here
LANGSMITH_PROJECT=tool-calling

# 非 US 区域可取消注释：
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
